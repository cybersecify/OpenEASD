# OpenEASD Django Environment Variables
# Copy this to .env and fill in your values

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite at data/openeasd.db)
DB_NAME=data/openeasd.db

# Celery broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#security-alerts

# Alert threshold (low/medium/high/critical)
ALERT_SEVERITY_THRESHOLD=high

# Security tools
USE_DOCKER_TOOLS=true
TOOL_SUBFINDER=subfinder
TOOL_NAABU=naabu
TOOL_NMAP=nmap
TOOL_NUCLEI=nuclei
