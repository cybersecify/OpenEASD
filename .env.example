# OpenEASD Django Environment Variables
# Copy this to .env and fill in your values

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite)
DB_NAME=data/openeasd.db

# Scheduler (daily scan time, IST)
SCAN_DAILY_HOUR=2
SCAN_DAILY_MINUTE=0
SCHEDULER_ENABLED=True

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
ALERT_SEVERITY_THRESHOLD=high

# Microsoft Teams notifications (optional)
TEAMS_WEBHOOK_URL=

# Tool binary paths (defaults to ~/.pdtm/go/bin/ for pdtm-installed tools)
# TOOL_SUBFINDER=/path/to/subfinder
# TOOL_DNSX=/path/to/dnsx
# TOOL_NAABU=/path/to/naabu
# TOOL_HTTPX=/path/to/httpx
# TOOL_NMAP=/path/to/nmap
# TOOL_NUCLEI=/path/to/nuclei
